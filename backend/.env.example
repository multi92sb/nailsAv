# Local backend example (.env)
# Used by serverless-offline and local scripts.

JWT_SECRET=local-dev-secret-change-me
SES_FROM_EMAIL=noreply@localhost.dev

ENABLE_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

AWS_REGION=eu-west-1
TABLE_NAME=NailBooking-stage

