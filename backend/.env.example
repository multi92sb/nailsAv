# Required
JWT_SECRET=change-me-to-a-long-random-secret
SES_FROM_EMAIL=noreply@yourdomain.com

# Optional – SMS via Twilio
ENABLE_SMS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# AWS (set via AWS CLI or environment; do not commit real credentials)
AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Local dev overrides (populated automatically by serverless-offline)
# IS_OFFLINE=true
