{
  "name": "nail-booking-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "serverless offline",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:prod": "serverless deploy --stage prod",
    "seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "test": "jest",
    "dynamo:start": "node tools/runDynamoLocal.js",
    "dynamo:admin": "node tools/runDynamoAdmin.js",
    "dynamo:create-table": "ts-node src/scripts/createTable.ts",
    "dynamo:seed": "npm run seed"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ses": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "twilio": "^5.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.143",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "dynamodb-admin": "^4.6.1",
    "dynamodb-localhost": "^0.0.9",
    "esbuild": "^0.21.5",
    "jest": "^29.7.0",
    "serverless": "^3.38.0",
    "serverless-esbuild": "^1.52.1",
    "serverless-offline": "^13.6.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.2"
  }
}
